# GameCraft-Bench environment overrides — copy to .env and edit, or `export` directly.
#
# Every GAMECRAFT_BENCH_* var below corresponds to a constant in gamecraft_bench/config.py.
# Values shown are the built-in defaults; you only need entries here for the
# ones you actually want to change. The repo does NOT auto-load .env; use:
#
#     set -a; source .env; set +a
#
# (or `direnv`, or just `export FOO=...` in your shell) before running harbor.

# --- Godot ------------------------------------------------------------------

# Path to the Godot 4 binary. Default: first `godot` on $PATH.
# Used by tests/test_outputs.py for headless runtime checks and by
# tools/screenshot.gd invocations.
GAMECRAFT_BENCH_GODOT_BIN=/usr/local/bin/godot

# Suppresses Godot's "running as root" stderr warning.
GODOT_SILENCE_ROOT_WARNING=1

# Xvfb display range used by verifier replay. Keep this away from the
# play service display pool (:300..:307).
GAMECRAFT_BENCH_XVFB_DISPLAY_START=400
GAMECRAFT_BENCH_XVFB_DISPLAY_END=700

# --- pytest -----------------------------------------------------------------

# Pytest binary used by tasks/<task>/tests/test.sh. Empty / "pytest" means
# rely on $PATH; set this to a venv's pytest if you don't activate the venv
# before running harbor.
GAMECRAFT_BENCH_PYTEST_BIN=pytest

# --- Sandbox ----------------------------------------------------------------

# Where LocalSubprocessEnvironment stages each trial.
# Default: <trial_dir>/sandbox (i.e. inside jobs/<job>/<trial>/), so you can
# `tail -f` the agent's workspace next to the trial logs.
# Override to a tmpfs path if you want fast local sandboxes detached from
# the jobs/ tree (e.g. for many concurrent trials).
#GAMECRAFT_BENCH_SANDBOX_ROOT=/tmp/gamecraft-bench-sandboxes

# --- Workspace template / assets / tools ------------------------------------

# Comma-separated subdirs of each task whose contents are copied into the
# sandbox's /workspace at env start. Default convention: tasks/<task>/workspace/.
GAMECRAFT_BENCH_WORKSPACE_TEMPLATE_DIRS=workspace

# Container-style absolute path the agent must produce its game project at.
# This is the contract between instruction.md, solve.sh, and verifier tests;
# don't change without updating those together.
GAME_PROJECT_PATH=/workspace/game

# Source dir for the shared CC0 asset pool, downloaded by scripts/fetch_assets.py.
# Default: <repo>/assets/library. The env class symlinks this into every
# sandbox at GAMECRAFT_BENCH_ASSET_LIBRARY_MOUNTPOINT.
GAMECRAFT_BENCH_ASSET_LIBRARY=assets/library

# Container-side path the asset library is exposed at.
GAMECRAFT_BENCH_ASSET_LIBRARY_MOUNTPOINT=/workspace/assets/library

# Source dir for the OpenGameArt CC0/CC-BY library, downloaded by
# scripts/fetch_oga_assets.py. Kept separate from the Kenney pool so
# license metadata (LICENSE.txt per entry) is preserved.
# Default: <repo>/assets/library-oga.
GAMECRAFT_BENCH_OGA_LIBRARY=assets/library-oga

# Container-side path the OGA library is exposed at.
GAMECRAFT_BENCH_OGA_LIBRARY_MOUNTPOINT=/workspace/assets/library-oga

# Source dir for the shared GDScript/shell helpers (e.g. screenshot.gd).
# Default: <repo>/tools. Symlinked into every sandbox at GAMECRAFT_BENCH_TOOLS_MOUNTPOINT.
GAMECRAFT_BENCH_TOOLS_DIR=tools

# Container-side path the tools dir is exposed at.
GAMECRAFT_BENCH_TOOLS_MOUNTPOINT=/workspace/tools

# --- Verifier judge ---------------------------------------------------------

# Which multimodal backend scores the demo replays.
# One of: stub | claude | opus | kimi | openai | gemini.
# Default: openai.
GAMECRAFT_BENCH_JUDGE=openai

# Optional model override. Each backend has its own default; set this only
# if you want a specific SKU. Examples: gemini-3.0, claude-opus-4-7, gpt-4o.
GAMECRAFT_BENCH_JUDGE_MODEL=gpt-5.5

# Set these when the judge needs a different key/url than the agent — e.g. the
# agent calls openai.com directly, but the judge goes through a cheaper
# multimodal proxy. Each judge tries its GAMECRAFT_BENCH_JUDGE_* var first, then
# falls back to the plain vendor name above. Leave unset to share creds with
# the agent.
GAMECRAFT_BENCH_JUDGE_OPENAI_API_KEY=your_openai_api_key_here
GAMECRAFT_BENCH_JUDGE_OPENAI_BASE_URL=your_openai_base_url_here
# Anthropic SDK accepts either a bearer token (proxies) or an api key
# (anthropic.com direct). The judge tries AUTH_TOKEN first, API_KEY second.
#GAMECRAFT_BENCH_JUDGE_ANTHROPIC_AUTH_TOKEN=
#GAMECRAFT_BENCH_JUDGE_ANTHROPIC_API_KEY=
#GAMECRAFT_BENCH_JUDGE_ANTHROPIC_BASE_URL=
#GAMECRAFT_BENCH_JUDGE_MOONSHOT_API_KEY=
#GAMECRAFT_BENCH_JUDGE_MOONSHOT_BASE_URL=
#GAMECRAFT_BENCH_JUDGE_GEMINI_API_KEY=
#GAMECRAFT_BENCH_JUDGE_GOOGLE_API_KEY=
#GAMECRAFT_BENCH_JUDGE_GEMINI_BASE_URL=
